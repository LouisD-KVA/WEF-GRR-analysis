geom_point(size = 2.5) +
geom_point(
data = filter(income_profile_target_long, Region == "HIC"),
size = 3.5, shape = 21, fill = "white", stroke = 1.0
) +
geom_text(
data = friedman_labs_targeted,
aes(x = Region, y = value, label = label),
inherit.aes = FALSE,
hjust = 0,
vjust = 1.25,
size = 3.1
) +
